rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ====================================================
    // 🛠️ FUNCIONES AUXILIARES (RBAC)
    // ====================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Lee los datos del usuario actual para saber su rol
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Funciones de validación de roles
    function isAdmin() {
      return isAuthenticated() && getUserData().role == 'admin';
    }

    function isStaff() {
      return isAuthenticated() && getUserData().role in ['admin', 'ventas', 'contabilidad', 'logistica'];
    }

    // ====================================================
    // 🔒 REGLAS DE NEGOCIO
    // ====================================================

    // 1. USUARIOS Y PERFILES
    match /users/{userId} {
      // Leer: El dueño puede ver su perfil. Los empleados pueden ver a todos.
      allow read: if isOwner(userId) || isStaff();
      
      // Crear: Cualquiera puede registrarse (se fuerza rol customer desde frontend/backend)
      // o un empleado puede crearlo desde el panel.
      allow create: if isOwner(userId) || isStaff();
      
      // Actualizar: 
      // - El admin puede actualizar TODO.
      // - Los empleados o el dueño pueden actualizar sus datos, PERO NO PUEDEN CAMBIAR SU ROL.
      allow update: if isAdmin() || (
        (isOwner(userId) || isStaff()) && 
        request.resource.data.role == resource.data.role // Bloquea la escalada de privilegios
      );
      
      allow delete: if isAdmin();
      
      match /addresses/{addressId} {
        allow read, write: if isOwner(userId) || isStaff();
      }
    }

    // 2. PRODUCTOS (CATÁLOGO)
    match /products/{productId} {
      // Todo el mundo puede ver los productos
      allow read: if true;
      
      // Solo empleados pueden crear o borrar
      allow create, delete: if isStaff();
      
      // Empleados pueden actualizar todo.
      // Clientes pueden actualizar SOLO el stock si compran directo sin Cloud Functions.
      allow update: if isStaff() || (
        isAuthenticated() && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stock', 'combinations', 'updatedAt'])
      );

      match /history/{historyId} {
        allow read, write: if isStaff();
      }
    }

    // 3. CATEGORÍAS Y MARCAS
    match /categories/{catId} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /brands/{brandId} {
      allow read: if true;
      allow write: if isStaff();
    }

    // 4. PEDIDOS (ORDERS)
    match /orders/{orderId} {
      // Se crea si el total es válido
      allow create: if request.resource.data.total >= 0; 
      
      // Solo el dueño, invitados de Mercadopago o Empleados pueden leer
      allow read: if isStaff() || (isAuthenticated() && resource.data.userId == request.auth.uid) || resource.data.userId == 'GUEST_MP';
      
      // Solo empleados gestionan estados
      allow update, delete: if isStaff();
    }

    // 5. REMISIONES Y GARANTÍAS
    match /remissions/{remissionId} {
      allow read, write: if isStaff();
    }

    match /warranties/{warrantyId} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read: if isStaff() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow update, delete: if isStaff();
    }

    // 6. CARRITO DE COMPRAS
    match /carts/{cartItemId} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // 7. GESTIÓN INTERNA (Logística y Contabilidad)
    match /warranty_inventory/{itemId} { allow read, write: if isStaff(); }
    match /suppliers/{supplierId} { allow read, write: if isStaff(); }
    match /purchases/{purchaseId} { allow read, write: if isStaff(); }
    match /expenses/{expenseId} { allow read, write: if isStaff(); }
    match /expenses_trash/{trashId} { allow read, write: if isStaff(); }
    match /accounts/{accountId} { allow read, write: if isStaff(); }
    match /payables/{payableId} { allow read, write: if isStaff(); }
    
    // 🔥 NUEVO: CÓDIGOS DE DESCUENTO Y USO (SEGURIDAD CRÍTICA)
    match /promo_codes/{promoId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /promo_usages/{usageId} {
      allow read, write: if isAdmin();
    }
    match /gift_cards/{cardId} {
      allow read, write: if isAdmin();
    }
    
    match /config/{configDoc} {
      allow read: if true;
      allow write: if isAdmin(); // Configuraciones críticas solo Admin
    }

    // 8. CHATS Y ESTADÍSTICAS (Marketing)
    match /chats/{chatId} {
      allow read, write: if isStaff();
      match /messages/{messageId} {
        allow read, write: if isStaff();
      }
    }
    
    match /stats/{statId} {
      // Necesario para el contador mensual de Marketing
      allow read, write: if isStaff();
    }
    
    // 🔥 NUEVO: Historial de Campañas Masivas
    match /campaigns_history/{campId} {
      allow read, write: if isStaff();
    }

    // 🏠 MULTI-SEDE Y CIERRES DE CAJA
    match /branches/{branchId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /transfers/{transferId} {
      allow read, write: if isStaff();
    }

    match /cash_closings/{closingId} {
      allow read, write: if isStaff();
    }
    
  }
}